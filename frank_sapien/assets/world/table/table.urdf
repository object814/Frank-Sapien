<?xml version="1.0"?>
<robot name="table">
  <link name="table_link">

    <visual name="table_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="table.stl" scale="1 1 1"/>
      </geometry>
      <material name="table_material">
        <color rgba="0.8 0.8 0.9 1"/>
      </material>
    </visual>

    <collision name="table_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="table.stl" scale="1 1 1"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia
        ixx="1.0" ixy="0.0" ixz="0.0"
        iyy="1.0" iyz="0.0"
        izz="1.0"/>
    </inertial>

  </link>
</robot>